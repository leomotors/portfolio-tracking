# Ignore dependencies (will be installed inside Docker)
node_modules/

# Ignore build outputs
dist/
out/
.build/
.turbo/
.next/
.vite/

# Ignore local env files and secrets at any depth.
# Templates (.env.template, .env.example) are explicitly re-included.
**/.env
**/.env.*
!**/.env.template
!**/.env.example

# Ignore system files
.git/
.gitignore
Dockerfile
docker-compose.yml
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
